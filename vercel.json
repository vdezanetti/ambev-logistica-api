{
  "version": 2,
  "builds": [
    { 
      "src": "api/index.js", 
      "use": "@vercel/node",
      "config": { "includeFiles": "api/data/**" }
    },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}